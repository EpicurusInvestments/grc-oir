# .env.example — Variables de entorno del Sistema GRC-OIR
#
# Instrucciones:
# 1) Copia este archivo como ".env" en la raíz del repo:  cp .env.example .env
# 2) Llena los valores reales (endpoint de AWS RDS, usuario, contraseña).
# 3) NUNCA subas el archivo .env al repositorio (ya está en .gitignore).
#    Las credenciales reales solo viven en la máquina de cada desarrollador
#    o en el gestor de secretos del entorno correspondiente.

# --- Base de datos: AWS RDS Microsoft SQL Server -----------------------------
# NOTA: estos son los datos de la instancia de DESARROLLO/PRUEBA. La CONTRASEÑA real
# NO se versiona: se rellena en el .env local (no versionado) o en AWS Secrets Manager.
# Conviene rotar la contraseña de prueba antes de pasar a producción.
# DB_HOST es el "endpoint" que da AWS RDS, p.ej.: grcoir-dev.xxxx.us-west-2.rds.amazonaws.com
DB_HOST=devapps.cyd2zy4jjmkm.us-west-2.rds.amazonaws.com
DB_PORT=1433
DB_NAME=GRC-OIR
DB_USER=TESTGRCOIRDB
# IMPORTANTE: si la contraseña contiene '$' (u otros caracteres especiales), enciérrala
# en COMILLAS SIMPLES. El cargador de .env (python-dotenv) interpola '$' como variable y
# mutila la contraseña si va sin comillas. Ej.: DB_PASSWORD='mi$$clave'
DB_PASSWORD=[[POR LLENAR: contraseña de la BD; no versionar — usar comillas simples si trae $]]

# Cifrado de la conexión (recomendado con RDS). Si la instancia usa el certificado
# de Amazon y el contenedor no lo tiene instalado, TrustServerCertificate=yes
# permite conectar; lo ideal es instalar el bundle de certificados de AWS.
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERTIFICATE=yes

# --- Backend -----------------------------------------------------------------
# Entorno de ejecución: development | qa | production
# IMPORTANTE: el acceso de desarrollo por headers (abajo) SOLO funciona en development.
# En qa/production sin SSO configurado, la autenticación falla cerrada (rechaza).
APP_ENV=development
# Llave para firmar tokens/sesiones (generar una aleatoria larga por entorno)
SECRET_KEY=[[POR LLENAR: generar con `python -c "import secrets; print(secrets.token_urlsafe(64))"`]]
# Tasa de IVA usada por los campos calculados (centralizada, según la spec = 16%)
IVA_RATE=0.16
# Orígenes permitidos por CORS (coma-separados, SIN barra final). En desarrollo, el
# frontend de Vite. En qa/producción, poner el/los dominio(s) reales del frontend.
# Ej. producción: CORS_ORIGINS=https://grc-oir.example.com
CORS_ORIGINS=http://localhost:5173

# --- Auth de desarrollo (mientras el SSO corporativo está [[POR LLENAR]]) -----
# Usuario/área por defecto cuando el request no envía X-Dev-User / X-Dev-Area.
# Áreas válidas: ventas | facturacion | tesoreria | cxc | cxp | direccion | nominas | admin
DEV_USER=dev.admin
DEV_AREA=admin

# --- SSO / Autenticación corporativa (por confirmar con IT de GRC) ------------
SSO_PROVIDER=[[POR LLENAR: azuread | google | otro]]
SSO_CLIENT_ID=[[POR LLENAR]]
SSO_CLIENT_SECRET=[[POR LLENAR]]
SSO_TENANT_ID=[[POR LLENAR: si aplica]]

# --- Frontend ------------------------------------------------------------------
# URL donde el frontend encuentra a la API (en local, el backend del compose)
VITE_API_URL=http://localhost:8000/api/v1
